# Meluko Manasa Podcast Studio — Environment Variables
# Copy this file to .env and fill in your keys

# PRIMARY: Gemini API key from https://aistudio.google.com/apikey
# New format starts with AQ. (Google's updated key format)
GEMINI_API_KEY=AQ.your_gemini_key_here

# FALLBACK: OpenAI API key (used if Gemini is unavailable)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here

PORT=3001
